# =============================================================================
# Flask backend (legacy) — server bind / debug / CORS
# =============================================================================
# Defaults are SAFE: loopback only, debug off, CORS limited to localhost.
# Override only when you understand the implications.

# FLASK_HOST=127.0.0.1
# FLASK_PORT=5040

# Set to "true" only on a host you fully control. NEVER combine FLASK_DEBUG=true
# with a non-loopback FLASK_HOST: the Werkzeug debugger is remote-code-execution.
# FLASK_DEBUG=false

# Comma-separated list of origins allowed to call the API from a browser.
# Use "*" only if you really mean "any origin" (anonymous read/write across
# tabs); otherwise list each origin explicitly.
# CORS_ALLOWED_ORIGINS=http://localhost:5040,http://127.0.0.1:5040

# How long a per-source ?source=<name> session pointer stays valid without a
# refresh, in seconds. Default 7200 (2 hours).
# SESSION_TTL_SECONDS=7200

# =============================================================================
# Whisper Model Configuration
# =============================================================================

# Two distinct models: "fast" is used when the audio queue is backed up,
# "smart" is used otherwise. Set them independently. Legacy WHISPER_MODEL
# is honoured as a fallback default for both if these are not set.
# WHISPER_MODEL_FAST=small
# WHISPER_MODEL_SMART=medium

# Legacy single-model setting (still respected as a default for both
# WHISPER_MODEL_FAST and WHISPER_MODEL_SMART). Prefer the two vars above.
# WHISPER_MODEL=small

# Set to "true" to delegate transcription to a whisper.cpp HTTP server
# instead of loading models in-process.
# WHISPER_SERVER_USE=false

# Base URL of the whisper.cpp server. The server appends /inference itself.
# WHISPER_SERVER=http://localhost:8007

# Hardware Selection (optional, defaults to cuda if available, else cpu)
# WHISPER_DEVICE=cpu

# =============================================================================
# Audio grabber client
# =============================================================================
# TRANSCRIBE_SERVER_URL=http://localhost:5040/transcripts
